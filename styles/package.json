{
  "name": "style",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "css:dist": "lightningcss --bundle --targets '>= 0.25%' src/css/style.css --output-file dist/css/style.css",
    "copy:fonts": "cpx 'src/fonts/**/*' dist/fonts",
    "copy:img": "cpx 'src/img/*.{jpg,png,svg,gif}' dist/img",
    "copy:img-mosaic": "cpx 'src/img/mosaic/*.{jpg,png,svg,gif}' dist/img/mosaic",
    "copy:img-svg": "cpx 'src/img/svg-img/*.svg' dist/img/svg",
    "copy:dist-other": "cpx 'other/**/*' dist/css",
    "copy:browser-dev": "cpx 'other/**/*' ../bundles/browser/resources/public/css",
    "copy:all": "npm-run-all --parallel copy:fonts copy:img copy:img-mosaic copy:img-svg copy:dist-other",
    "svgmin": "svgo -f src/img/svg -o src/img/svg/svgmin --config svgo.config.js",
    "svgcss": "node scripts/svg-to-css.js",
    "cssmin": "lightningcss --minify --bundle --targets '>= 0.25%' dist/css/*.css --output-dir dist/css && lightningcss --minify --bundle --targets '>= 0.25%' dist/css/1_vendor/*.css --output-dir dist/css/1_vendor",
    "css:watch": "chokidar 'src/css/**/*.css' -c 'npm run css:dist'",
    "watch:css": "npm run css:watch",
    "watch:img": "chokidar 'src/img/*.{jpg,png,svg,gif}' -c 'npm run copy:img'",
    "watch:img-mosaic": "chokidar 'src/img/mosaic/*.{jpg,png,svg,gif}' -c 'npm run copy:img-mosaic'",
    "watch:img-svg": "chokidar 'src/img/svg-img/*.svg' -c 'npm run copy:img-svg'",
    "watch:fonts": "chokidar 'src/fonts/**/*' -c 'npm run copy:fonts'",
    "watch:svg": "chokidar 'src/img/svg/*.svg' -c 'npm run svgmin && npm run svgcss'",
    "watch:other": "chokidar 'other/**/*' -c 'npm run copy:dist-other && npm run copy:browser-dev'",
    "watch:tailwind": "npm run tailwind:watch",
    "watch:all": "npm-run-all --parallel watch:*",
    "serve": "browser-sync start --server --files 'dist/**/*' --port 8020",
    "tailwind:dist": "tailwindcss -i src/tailwind.css -o dist/css/5_utilities.css",
    "tailwind:watch": "tailwindcss -i src/tailwind.css -o dist/css/5_utilities.css --watch",
    "init": "npm run build",
    "build": "npm-run-all svgmin svgcss css:dist copy:all tailwind:dist",
    "build:prod": "npm-run-all svgmin svgcss css:dist copy:all tailwind:dist cssmin",
    "dev": "npm-run-all build --parallel watch:all serve"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.2",
    "browser-sync": "3.0.4",
    "chokidar-cli": "3.0.0",
    "cpx2": "7.0.2",
    "lightningcss-cli": "1.32.0",
    "npm-run-all": "4.1.5",
    "svgo": "3.3.3",
    "tailwindcss": "4.3.2"
  }
}
